# Variables para docker-compose.yml
# Copia este archivo a .env.docker y actualiza los valores

# PostgreSQL (base de datos local)
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Supabase Auth (JWT y configuración OAuth)
GOTRUE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Google OAuth (opcional, para login con Google)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Supabase API keys
SUPABASE_SERVICE_ROLE_KEY=super-secret-service-key
SUPABASE_ANON_KEY=public-anon-key

# CoinGecko API (opcional, para datos de cripto)
COINGECKO_API_KEY=

# Seed del usuario administrador inicial
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Change123!@#
