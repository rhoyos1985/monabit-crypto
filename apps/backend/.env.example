PORT=8080
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=optional-demo-key
CORS_ORIGIN=http://localhost:5173
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong-password
LOG_LEVEL=info
OTEL_SERVICE_NAME=monabit-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Cifrado de extremo a extremo (auth y users). El backend solo necesita la llave
# privada para descifrar las peticiones; la publica se inyecta en el bundle del
# frontend en build time (VITE_CRYPTO_PUBLIC_KEY). En desarrollo, si no se
# define, se genera una privada efimera. En produccion es obligatoria. PEM en
# una linea con \n.
CRYPTO_PRIVATE_KEY=
