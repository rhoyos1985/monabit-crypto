# Ruta relativa al mismo origen. El SPA llama a /api y un reverse proxy lo
# reenvia al backend (Vite en dev, nginx en prod). Mismo origen => la cookie
# httpOnly de sesion (SameSite=Lax) viaja sin ser cookie de terceros.
VITE_API_BASE_URL=/api
# Destino del proxy del dev server de Vite (solo en desarrollo). Apunta al
# backend local; en Docker Compose se fija a http://backend:8080.
VITE_PROXY_TARGET=http://localhost:8080
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Cifrado de extremo a extremo en auth y users. Activado por defecto;
# poner en 'false' para desactivarlo.
VITE_ENCRYPTION_ENABLED=true
# Llave publica RSA del backend (PEM SPKI). Se inyecta en build time
# (--build-arg VITE_CRYPTO_PUBLIC_KEY) y se embebe en el bundle de Vite.
# El frontend NUNCA la pide por HTTP al backend. PEM en una linea con \n.
VITE_CRYPTO_PUBLIC_KEY=
