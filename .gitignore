.pnpm-debug.log

# Build outputs
dist/
build/
.next/
out/

# Compiled TypeScript in source directories (should not be committed)
apps/frontend/src/**/*.d.ts
apps/frontend/src/**/*.d.ts.map
apps/frontend/src/**/*.js
apps/frontend/src/**/*.js.map
apps/backend/src/**/*.d.ts
apps/backend/src/**/*.d.ts.map
# Excepciones: archivos .d.ts que son fuente (no generados), necesarios para typecheck/lint
!apps/frontend/src/shared/styled.d.ts
!apps/frontend/src/vite-env.d.ts
!apps/backend/src/shared/swagger-jsdoc.d.ts

# Config files exceptions
!vite.config.ts
!commitlint.config.js

