# Copiar a terraform.tfvars y completar (este archivo NO se commitea).
# Los valores reales se inyectan desde GitHub Actions con TF_VAR_* env vars.

project_id         = "your-gcp-project-id"
region             = "us-central1"
environment        = "prod"
github_repository  = "owner/monabit-crypto"

backend_image  = "us-central1-docker.pkg.dev/your-gcp-project-id/monabit-prod/backend:latest"
frontend_image = "us-central1-docker.pkg.dev/your-gcp-project-id/monabit-prod/frontend:latest"

supabase_url              = "https://your-project.supabase.co"
supabase_service_role_key = "..."
supabase_anon_key         = "..."

seed_admin_email    = "admin@example.com"
seed_admin_password = "..."

# Llave privada RSA para descifrar las peticiones (la publica vive como
# secreto de GitHub Actions y se inyecta como --build-arg
# VITE_CRYPTO_PUBLIC_KEY al construir la imagen del frontend).
# Generar el par con:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
#   openssl rsa -in private.pem -pubout -out public.pem
crypto_private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
